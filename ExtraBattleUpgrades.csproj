  </Target>

  <ItemGroup>
    <EmbeddedResource Include="Assets\extra_battle_upgrades_assets" LogicalName="ExtraBattleUpgrades.Assets.extra_battle_upgrades_assets" Condition="Exists('Assets\extra_battle_upgrades_assets')" />
  </ItemGroup>

