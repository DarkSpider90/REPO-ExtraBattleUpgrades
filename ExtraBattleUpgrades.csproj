<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>ExtraBattleUpgrades</AssemblyName>
    <RootNamespace>ExtraBattleUpgrades</RootNamespace>
    <Version>1.0.0</Version>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <Target Name="RequireAssetBundle" BeforeTargets="BeforeBuild" Condition="'$(SkipAssetBundleCheck)' != 'true' And !Exists('Assets\extra_battle_upgrades_assets')">
